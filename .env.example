# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# TELEGRAM BOT CONFIG
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
BOT_USERNAME="AutosVerify_bot"
ADMIN_ID="8125978050"
ADMIN_PASSWORD="admin123"

# DATABASE
ENCRYPTION_KEY="default_secret_key_32_bytes_long____"

# FIREBASE (Required for cloud database sync)
# Paste the full JSON content of your Firebase service account key here (single line, minified)
FIREBASE_SERVICE_ACCOUNT=""

# CHANNELS/GROUPS
REQUIRED_CHANNEL_NAME="@AutosVerify"
REQUIRED_GROUP_NAME="@AutosVerifyCh"
REQUIRED_CHANNEL_ID="-1002088203586"
REQUIRED_GROUP_ID="-1002188442004"
SKIP_MANDATORY_JOIN="true"

# EXTERNAL APIS
OPENAI_API_KEY=""
SMTPLABS_API_KEY=""

# BACKUP
BACKUP_BOT_TOKEN=""
BACKUP_CHAT_ID="8125978050"

# PROXY (Optional)
USE_PROXY="false"
PROXY_URL=""

# ALLOWED HELPER ADMIN IDs (comma-separated, optional)
ALLOWED_USER_IDS="8125978050"
